# JClaw 本地环境变量配置模板
# 复制此文件为 .env.local 并填入真实值
# ⚠️ 警告：.env.local 包含敏感信息，切勿提交到代码仓！

# ===========================================
# 数据库配置
# ===========================================
DB_HOST=localhost
DB_PORT=3306
DB_NAME=jclaw
DB_USER=root
DB_PASSWORD=your_mysql_password_here

# ===========================================
# Redis 配置（缓存 - 记忆 L1 层）
# ===========================================
REDIS_HOST=localhost
REDIS_PORT=6380
# REDIS_PASSWORD=  # 如果需要密码

# ===========================================
# FalkorDB 配置（图数据库 - 意图图谱/代码追溯）
# ===========================================
FALKORDB_HOST=localhost
FALKORDB_PORT=6379
# FALKORDB_PASSWORD=  # 如果需要密码

# ===========================================
# AI API Keys（按需配置，不要的全部留空）
# ===========================================

# 智谱 AI（GLM 模型）
ZHIPU_API_KEY=your_zhipu_api_key_here

# 月之暗面（Kimi 模型）
MOONSHOT_API_KEY=your_moonshot_api_key_here

# 阿里云（Qwen 模型）
ALIYUN_API_KEY=your_aliyun_api_key_here

# OpenAI（如果需要）
OPENAI_API_KEY=your_openai_api_key_here

# ===========================================
# JWT 配置
# ===========================================
JWT_SECRET=your_jwt_secret_key_must_be_at_least_256_bits_long_please_change_this
JWT_EXPIRATION=86400000

# ===========================================
# 加密配置
# ===========================================
ENCRYPTION_KEY=your_encryption_key_here

# ===========================================
# 其他配置
# ===========================================
LOG_LEVEL=INFO
SPRING_PROFILES_ACTIVE=dev
