#!/bin/bash
# JClaw 启动脚本
# 用法：./jclaw start|stop|restart|status

set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
JAR_FILE="$SCRIPT_DIR/target/jclaw-1.0.0.jar"
PID_FILE="$SCRIPT_DIR/jclaw.pid"
LOG_DIR="$SCRIPT_DIR/logs"
CONFIG_FILE="$SCRIPT_DIR/application.yml"

# 颜色输出
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

log_info() {
    echo -e "${GREEN}[INFO]${NC} $1"
}

log_warn() {
    echo -e "${YELLOW}[WARN]${NC} $1"
}

log_error() {
    echo -e "${RED}[ERROR]${NC} $1"
}

check_java() {
    if ! command -v java &> /dev/null; then
        log_error "Java 未安装，请先安装 Java 17+"
        exit 1
    fi
    
    JAVA_VERSION=$(java -version 2>&1 | head -1 | cut -d'"' -f2 | cut -d'.' -f1)
    if [ "$JAVA_VERSION" -lt 17 ]; then
        log_error "需要 Java 17 或更高版本，当前版本：$JAVA_VERSION"
        exit 1
    fi
    
    log_info "Java 版本检查通过：$JAVA_VERSION"
}

check_config() {
    if [ ! -f "$CONFIG_FILE" ]; then
        log_warn "配置文件不存在，从示例创建..."
        cp "$SCRIPT_DIR/src/main/resources/application.yml.example" "$CONFIG_FILE"
        log_warn "请编辑 $CONFIG_FILE 配置 API Key 等必要参数"
    fi
}

start() {
    if [ -f "$PID_FILE" ]; then
        PID=$(cat "$PID_FILE")
        if ps -p $PID > /dev/null 2>&1; then
            log_warn "JClaw 已在运行 (PID: $PID)"
            exit 0
        fi
    fi
    
    check_java
    check_config
    
    if [ ! -f "$JAR_FILE" ]; then
        log_error "JAR 文件不存在：$JAR_FILE"
        log_info "请先执行：mvn clean package -DskipTests"
        exit 1
    fi
    
    mkdir -p "$LOG_DIR"
    
    log_info "启动 JClaw..."
    nohup java -jar "$JAR_FILE" \
        --spring.config.location="file:$CONFIG_FILE" \
        > "$LOG_DIR/jclaw.out" 2>&1 &
    
    echo $! > "$PID_FILE"
    sleep 2
    
    if ps -p $(cat "$PID_FILE") > /dev/null 2>&1; then
        log_info "JClaw 启动成功 (PID: $(cat "$PID_FILE"))"
        log_info "日志文件：$LOG_DIR/jclaw.log"
    else
        log_error "JClaw 启动失败，请查看日志：$LOG_DIR/jclaw.out"
        rm -f "$PID_FILE"
        exit 1
    fi
}

stop() {
    if [ ! -f "$PID_FILE" ]; then
        log_warn "JClaw 未运行"
        return
    fi
    
    PID=$(cat "$PID_FILE")
    if ps -p $PID > /dev/null 2>&1; then
        log_info "停止 JClaw (PID: $PID)..."
        kill $PID
        sleep 2
        
        if ps -p $PID > /dev/null 2>&1; then
            log_warn "进程未停止，强制终止..."
            kill -9 $PID
        fi
        
        log_info "JClaw 已停止"
    else
        log_warn "进程不存在，清理 PID 文件"
    fi
    
    rm -f "$PID_FILE"
}

restart() {
    stop
    sleep 1
    start
}

status() {
    if [ -f "$PID_FILE" ]; then
        PID=$(cat "$PID_FILE")
        if ps -p $PID > /dev/null 2>&1; then
            log_info "JClaw 运行中 (PID: $PID)"
            ps -p $PID -o pid,etime,cmd
        else
            log_warn "PID 文件存在但进程不存在"
            rm -f "$PID_FILE"
        fi
    else
        log_info "JClaw 未运行"
    fi
}

case "${1:-status}" in
    start)
        start
        ;;
    stop)
        stop
        ;;
    restart)
        restart
        ;;
    status)
        status
        ;;
    *)
        echo "用法：$0 {start|stop|restart|status}"
        exit 1
        ;;
esac
